  "version": "1.0.0",
  "description": "Central Point (Webhook + Redis) - Crypto Payment System",
  "license": "ISC",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
