{
  "name": "core",
  "version": "1.0.0",
  "description": "Central Point (Webhook + Redis) - Crypto Payment System",
  "license": "ISC",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:backup": "node scripts/db-backup.cjs",
    "db:restore": "node scripts/db-restore.cjs",
    "db:supabase:push": "node supabase/push.cjs",
    "db:supabase:status": "node scripts/run-supabase.cjs status",
    "db:seed": "prisma db seed",
    "db:seed-chains-tokens": "tsx scripts/seed-chains-tokens-from-backend.ts",
    "db:studio": "prisma studio",
    "db:export": "tsx scripts/db-export.ts",
    "db:import": "tsx scripts/db-import.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "pnpm db:generate && vitest run",
    "test:live": "tsx scripts/test-live.ts",
    "test:live:onramp-offramp": "tsx scripts/test-live-onramp-offramp.ts",
    "test:live:requests-payouts": "tsx scripts/test-live-requests-payouts.ts",
    "e2e:cli": "tsx scripts/e2e-cli.ts",
    "e2e:cli:requests-claims": "tsx scripts/e2e-cli-requests-claims.ts",
    "key:generate": "tsx scripts/generate-backend-key.ts",
    "sent:push-templates": "tsx scripts/push-sent-templates.ts",
    "seed:merchant-dashboard-mock": "tsx scripts/seed-merchant-dashboard-mock.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@simplewebauthn/server": "^13.2.2",
    "argon2": "^0.44.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "otplib": "^13.2.1",
    "pusher": "^5.2.0",
    "resend": "^6.9.2",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.0",
    "@types/node": "^22.0.0",
    "prisma": "^7.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
