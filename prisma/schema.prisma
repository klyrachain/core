// Prisma schema - Crypto Payment System (Central Point)
// See md/rules for conventions.
// Prisma 7: provider prisma-client, output required; datasource url in prisma.config.ts

generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------
// Enums
// --------------------------------------

enum TransactionType {
  BUY
  SELL
  TRANSFER
  REQUEST
  CLAIM
}

enum TransactionStatus {
  ACTIVE
  PENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum ClaimStatus {
  ACTIVE
  CLAIMED
  CANCELLED
  FAIL
}

enum PaymentProvider {
  NONE
  ANY
  KLYRA   // On-chain same-chain; we have balance and send to user
  SQUID
  LIFI
  PAYSTACK
}

enum CryptoTransactionStatus {
  PENDING   // Quote accepted; swap not yet submitted
  SUBMITTED // Tx sent to chain; awaiting confirmation
  CONFIRMED // On-chain confirmed
  FAILED    // Submit failed or chain reverted
}

enum IdentityType {
  ADDRESS
  EMAIL
  NUMBER
}

enum SupportedChain {
  ETHEREUM
  BNB
  BASE
  SOLANA
}

enum InvoiceStatus {
  Paid
  Pending
  Overdue
  Draft
  Cancelled
}

// --------------------------------------
// Enums (Business / B2B2C)
// --------------------------------------

enum BusinessRole {
  OWNER
  ADMIN
  DEVELOPER
  FINANCE
  SUPPORT
}

enum KybStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
  RESTRICTED // Frozen funds
}

enum SettlementSchedule {
  INSTANT
  DAILY
  WEEKLY
  MANUAL
}

enum MerchantSignupRole {
  DEVELOPER
  FOUNDER_EXECUTIVE
  FINANCE_OPS
  PRODUCT
}

enum MerchantPrimaryGoal {
  ACCEPT_PAYMENTS
  SEND_PAYOUTS
  INTEGRATE_SDK
  EXPLORING
}

enum PayoutMethodType {
  BANK_ACCOUNT
  CRYPTO_WALLET
  MOBILE_MONEY
}

enum PayoutStatus {
  SCHEDULED
  PROCESSING
  PAID
  FAILED
  REVERSED
}

// --------------------------------------
// Commerce (merchant catalog & pay pages)
// --------------------------------------

enum PaymentLinkType {
  STANDARD // Open or fixed amount "Pay me"
  PRODUCT // Tied to a catalog product
  DONATION // Open amount, donation framing
}

enum ProductType {
  DIGITAL
  PHYSICAL
  SERVICE
}

/// Test vs live isolation for merchant data (Stripe-style).
enum MerchantEnvironment {
  TEST
  LIVE
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

enum LotStatus {
  OPEN
  DEPLETED
}

enum LedgerType {
  ACQUIRED
  DISPOSED
  REBALANCE
}

// --------------------------------------
// Core Models
// --------------------------------------

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email    String  @unique
  address  String? @unique
  number   String? // e.g. 233...
  username String?

  /// Business portal: email/password signup (null if Google- or magic-link-only).
  passwordHash String?
  /// Google OAuth subject; links account when email matches or sub is unique.
  googleSub    String? @unique
  /// Business portal profile name (shown after onboarding).
  portalDisplayName String?
  portalPasskeys    UserPortalPasskey[]

  transactionsFrom Transaction[] @relation("FromUser")
  transactionsTo   Transaction[] @relation("ToUser")
  members          BusinessMember[]
  merchantOnboarding MerchantOnboarding?
  merchantCustomers MerchantCustomer[]

  @@index([email, address, username])
}

/// Progressive business signup (Typeform steps 2–3) before Business is created.
model MerchantOnboarding {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String?
  website     String?
  signupRole  MerchantSignupRole?
  primaryGoal MerchantPrimaryGoal?

  @@index([userId])
}

/// WebAuthn passkey for business portal (User), distinct from admin passkeys.
model UserPortalPasskey {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String   @unique
  publicKey    Bytes
  counter      Int      @default(0)
  name         String?

  @@index([userId])
  @@index([credentialId])
}

model Transaction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type   TransactionType
  status TransactionStatus @default(ACTIVE)

  fromIdentifier String?
  fromType       IdentityType?
  fromUserId     String?
  fromUser       User?         @relation("FromUser", fields: [fromUserId], references: [id])

  toIdentifier String?
  toType       IdentityType?
  toUserId     String?
  toUser       User?         @relation("ToUser", fields: [toUserId], references: [id])

  f_amount Decimal @db.Decimal(18, 8)
  t_amount Decimal @db.Decimal(18, 8)
  /// Effective rate for the trade: t_amount / f_amount (units of to-token per unit of from-token).
  exchangeRate    Decimal?  @db.Decimal(18, 8)
  /// Price of 1 unit of FROM token in USD (e.g. 1.00 for USDC, ~0.064 for GHS).
  f_tokenPriceUsd Decimal?  @db.Decimal(18, 8)
  /// Price of 1 unit of TO token in USD (e.g. 1.00 for USDC, ~0.064 for GHS).
  t_tokenPriceUsd Decimal?  @db.Decimal(18, 8)
  /// Fee value in USD at completion (fee amount × token price USD).
  feeInUsd Decimal? @db.Decimal(18, 8)

  f_chain  String  // Source chain (e.g. ETHEREUM, BASE)
  t_chain  String  // Target chain (e.g. ETHEREUM, BASE) — enables cross-chain e.g. USDC on BASE → USDT on ETHEREUM
  f_token  String
  t_token  String

  f_provider PaymentProvider @default(NONE)
  t_provider PaymentProvider @default(NONE)

  providerSessionId String? // External provider session (e.g. PayStack); link for session-based providers
  /// Onramp BUY: set when Paystack charge.success received; COMPLETED is set only after crypto send.
  paymentConfirmedAt DateTime?

  businessId String? // Optional: if this tx was initiated via API by a merchant
  business   Business? @relation("BusinessTransactions", fields: [businessId], references: [id], onDelete: SetNull)

  environment MerchantEnvironment @default(LIVE)

  /// Merchant commerce: pay page / product attribution (optional).
  paymentLinkId String?
  paymentLink   PaymentLink? @relation(fields: [paymentLinkId], references: [id], onDelete: SetNull)
  productId     String?
  product       Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  /// Cart / multi-line display for merchant UI, e.g. [{ productId, name, qty, unitPrice }].
  lineItems Json?

  platformFee Decimal? @default(0) @db.Decimal(18, 8) // Platform cut
  merchantFee Decimal? @default(0) @db.Decimal(18, 8) // Merchant markup (if any)
  fee        Decimal? @db.Decimal(18, 8) // Fee charged for this transaction (set when status = COMPLETED)
  providerPrice Decimal? @db.Decimal(18, 8) // Provider quote at order time (e.g. onramp: provider buy price)
  /// For request/claim: original provider quote used at settlement (not pricing-engine); for P&L tracking.
  settlementQuoteSnapshot Json?

  /// Onramp: tx hash of crypto send from liquidity pool to user (set when send completes).
  cryptoSendTxHash String?

  request   Request?
  requestId String?  @unique

  payoutRequests PayoutRequest[]
  paystackPaymentRecords PaystackPaymentRecord[]
  cryptoTransactions CryptoTransaction[]
  transactionPnLs TransactionPnL[]
  transactionBalanceSnapshots TransactionBalanceSnapshot[]
  refunds                     Refund[]
  webhookDeliveryLogs         WebhookDeliveryLog[]

  @@index([status, type])
  @@index([businessId])
  @@index([businessId, environment])
  @@index([paymentLinkId])
  @@index([productId])
}

/// Balance before/after for each asset affected by a transaction (audit trail; avoids wrong balance when concurrent txs).
model TransactionBalanceSnapshot {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  assetId       String
  asset         InventoryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  balanceBefore Decimal @db.Decimal(28, 8)
  balanceAfter  Decimal @db.Decimal(28, 8)

  @@index([transactionId])
  @@index([assetId])
}

// Profit & loss per lot used in a sale (FIFO). All amounts in USD.
model TransactionPnL {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  lotId         String?
  lot           InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)

  quantity        Decimal @db.Decimal(28, 8) // tokens sold from this lot
  costPerTokenUsd Decimal @db.Decimal(28, 8) // lot cost basis in USD per token
  feeAmountUsd    Decimal @db.Decimal(28, 8) // (selling - provider) * qty in USD
  profitLossUsd  Decimal @db.Decimal(28, 8) // (selling - cost) * qty in USD

  @@index([transactionId])
  @@index([lotId])
}

// --------------------------------------
// Crypto / Swap Transaction (router audit)
// --------------------------------------
// Tracks swap executions via 0x, Squid, LiFi. When a user picks a quote and proceeds,
// we record the swap; when we have the on-chain tx hash we update. Enables search by
// transaction ID and linking onramp/offramp to Paystack via transactionId.

model CryptoTransaction {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  provider     String   // "0x" | "squid" | "lifi"
  status       CryptoTransactionStatus @default(PENDING)

  fromChainId  Int
  toChainId    Int
  fromToken    String   // Contract address or native
  toToken      String
  fromAmount   String   // Wei/smallest unit
  toAmount     String

  txHash       String?  // Blockchain tx hash once submitted/confirmed
  txUrl        String?  // Block explorer link (optional)

  transactionId String?  // Our business Transaction when part of onramp/offramp
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  metadata     Json?    // Optional: quote snapshot, from_address, to_address, etc.

  @@index([transactionId])
  @@index([txHash])
  @@index([provider, status])
  @@index([createdAt])
}

model Request {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code       String @unique
  linkId     String @unique

  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  /// Merchant scope (nullable for legacy platform-created requests).
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  environment MerchantEnvironment @default(LIVE)

  /// When set, payment is auto-settled to this address (crypto: 0x...). Requester does not claim.
  payoutTarget String?

  /// Verified fiat payout: { type: "nuban"|"mobile_money", account_name, account_number, bank_code?, currency }. Set when requester wants fiat; verified via Paystack resolve/validate before create.
  payoutFiat   Json?

  claim Claim?

  @@index([businessId])
}

model Claim {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestId String  @unique
  request   Request @relation(fields: [requestId], references: [id])

  status ClaimStatus @default(ACTIVE)

  value Decimal @db.Decimal(18, 8)
  price Decimal @db.Decimal(18, 8)
  token String

  payerIdentifier String
  toIdentifier    String

  code String
  /// Set when recipient verifies OTP (email/phone); claim allowed only after this.
  otpVerifiedAt DateTime?
}

// --------------------------------------
// Internal System Models
// --------------------------------------

model Wallet {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address          String   @unique
  encryptedKey     String
  supportedChains  String[] // e.g. ["ETHEREUM", "BASE"]
  supportedTokens  String[] // e.g. ["ETH", "USDC"]

  /// Exactly one wallet should be true; used for onramp send, offramp receive, request/claim crypto.
  isLiquidityPool Boolean @default(false)
  /// Optional; where integrator/swap fees are sent (can be same or different wallet).
  collectFees Boolean @default(false)

  inventoryAssets InventoryAsset[]
}

model InventoryAsset {
  id        String   @id @default(uuid())
  updatedAt DateTime @updatedAt

  chain        String   // display name e.g. ETHEREUM, BASE
  chainId      Int      // chain ID e.g. 1, 8453
  tokenAddress String
  symbol       String
  address      String   // wallet/account address that holds this balance (not unique)

  currentBalance Decimal @default(0) @db.Decimal(28, 8)

  walletId String?
  wallet   Wallet?           @relation(fields: [walletId], references: [id], onDelete: SetNull)
  ledger   InventoryLedger[]
  lots     InventoryLot[]
  transactionBalanceSnapshots TransactionBalanceSnapshot[]

  @@unique([chainId, tokenAddress, address])
  @@index([address])
  @@index([walletId])
}

// Order-book style lots: each acquisition is a lot with USD cost basis. Fulfill sell orders FIFO.
model InventoryLot {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  assetId String
  asset   InventoryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  originalQuantity  Decimal @db.Decimal(28, 8) // how much we acquired in this lot
  remainingQuantity Decimal @db.Decimal(28, 8) // how much is left (FIFO deduction)
  costPerTokenUsd   Decimal @db.Decimal(28, 8) // USD price per token at acquisition
  totalCostUsd      Decimal @db.Decimal(28, 8) // originalQuantity * costPerTokenUsd
  status            LotStatus @default(OPEN)   // OPEN or DEPLETED
  acquiredAt        DateTime  @default(now())

  sourceType          String?  // e.g. PURCHASE, REBALANCE
  sourceTransactionId String?  // link to Transaction that created this lot

  transactionPnLs TransactionPnL[]

  @@index([assetId, acquiredAt])
  @@index([sourceTransactionId])
  @@index([assetId, status])
}

// Audit trail of every inventory movement (in/out). USD-denominated.
model InventoryLedger {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  assetId String
  asset   InventoryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  type   LedgerType // ACQUIRED (in), DISPOSED (out), REBALANCE
  quantity Decimal @db.Decimal(28, 8) // positive = in, negative = out
  pricePerTokenUsd Decimal @db.Decimal(28, 8) // USD price at time of event
  totalValueUsd    Decimal @db.Decimal(28, 8) // |quantity| * pricePerTokenUsd

  referenceId  String  // transaction id or order id
  counterparty String? // optional: user id or liquidity provider

  @@index([assetId])
  @@index([createdAt])
}

// --------------------------------------
// Supported Countries (onramp/offramp, payouts)
// --------------------------------------
// Country code (e.g. GH, NG), currency (e.g. GHS, NGN). Used for quotes and payouts.
// supportedFonbnk / supportedPaystack indicate which provider supports this country.

model Country {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code             String   @unique // ISO 3166-1 alpha-2, e.g. GH, NG
  name             String   // e.g. Ghana, Nigeria
  currency         String   // ISO 4217, e.g. GHS, NGN
  supportedFonbnk  Boolean  @default(false)
  supportedPaystack Boolean @default(false)

  @@index([code])
  @@index([supportedFonbnk, supportedPaystack])
}

// --------------------------------------
// Supported Chains & Tokens (onramp/offramp, quotes, transfers)
// --------------------------------------
// Managed via admin; consumed by GET /api/chains and GET /api/tokens.
// Used for pool-token lookup (Fonbnk intermediate, direct quotes).
// Model "Chain" maps to table "Chain" so the table does not conflict with enum type SupportedChain (ETHEREUM, BNB, BASE, SOLANA).

model Chain {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chainId   BigInt  @unique // numeric (1, 8453) or stable hash of string ID (e.g. "agoric-3")
  name      String  // e.g. Base, Ethereum
  iconUri   String? // optional chain icon URL (logo)
  rpcUrl    String? // primary RPC (first in list)
  rpcUrls   Json?   // array of RPC URLs from chain + tokens, deduped (string[])

  @@index([chainId])
  @@map("Chain")
}

model SupportedToken {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chainId       BigInt  // chain ID; match Chain.chainId
  tokenAddress  String  // contract address or native sentinel (e.g. 0xEee...)
  symbol        String  // e.g. USDC, ETH
  decimals      Int     @default(18)
  name          String? // e.g. USD Coin
  logoUri       String? // optional token icon URL (logo)
  fonbnkCode    String? // Fonbnk NETWORK_ASSET e.g. BASE_USDC, ETHEREUM_NATIVE
  /// Composite symbol for display and lookup: "BASE USDC", "ETHEREUM MANA". Resolve to chainId+address without extra services.
  displaySymbol String?

  @@unique([chainId, tokenAddress])
  @@index([chainId])
  @@index([symbol])
  @@index([displaySymbol])
}

// --------------------------------------
// Business (B2B2C: Platform–Merchant–User)
// --------------------------------------

model Business {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String  // e.g. "Amazon Inc"
  slug         String  @unique // e.g. "amazon" (for public payment links)
  logoUrl      String?
  website      String?
  supportEmail String?

  legalName          String? // Official registered name (KYB)
  registrationNumber String? // Tax ID / EIN / RC Number
  country            String  // ISO code e.g. "GH", "US"
  kybStatus          KybStatus @default(NOT_STARTED)
  riskScore          Int       @default(0) // 0–100, 100 is high risk

  settlementSchedule SettlementSchedule @default(WEEKLY)
  webhookUrl          String? // Main webhook for business events (legacy; prefer WebhookEndpoint)

  /// Checkout / hosted pay page branding
  brandColor        String?
  buttonColor       String?
  supportUrl        String?
  termsOfServiceUrl String?
  returnPolicyUrl   String?

  members       BusinessMember[]
  memberInvites BusinessMemberInvite[]
  apiKeys       ApiKey[]
  transactions  Transaction[]    @relation("BusinessTransactions")
  products      Product[]
  paymentLinks  PaymentLink[]
  invoices      Invoice[]
  requests      Request[]
  payoutMethods PayoutMethod[]
  payouts       Payout[]
  feeSchedule   FeeSchedule?
  merchantCustomers MerchantCustomer[]
  webhookEndpoints WebhookEndpoint[]
  refunds       Refund[]
}

// --------------------------------------
// Commerce (Merchant: catalog & pay pages)
// --------------------------------------

model Product {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  environment MerchantEnvironment @default(LIVE)

  name        String
  description String?
  type        ProductType @default(DIGITAL)

  price    Decimal @db.Decimal(18, 2)
  currency String  @default("USD")

  imageUrl   String?
  isActive   Boolean @default(true)
  isArchived Boolean @default(false)

  paymentLinks PaymentLink[]
  transactions Transaction[]

  @@index([businessId])
  @@index([businessId, environment])
  @@index([isActive])
}

model PaymentLink {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  environment MerchantEnvironment @default(LIVE)

  title       String
  description String?
  slug        String @unique

  type PaymentLinkType @default(STANDARD)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  amount   Decimal? @db.Decimal(18, 2)
  currency String   @default("USD")

  isActive Boolean @default(true)
  views    Int     @default(0)

  transactions Transaction[]

  @@index([businessId])
  @@index([businessId, environment])
  @@index([slug])
}

/// Merchant-scoped CRM: one row per business × contact (email/phone/user).
model MerchantCustomer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  environment MerchantEnvironment @default(LIVE)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  email       String?
  phone       String?
  displayName String?
  externalId  String? // Merchant's own reference id

  totalSpend Decimal @default(0) @db.Decimal(18, 2)
  orderCount Int     @default(0)

  notes    String?
  metadata Json?

  firstSeenAt    DateTime?
  lastActivityAt DateTime?

  @@index([businessId])
  @@index([businessId, environment])
  @@index([email])
  @@index([userId])
}

/// Pending team invite: user accepts via portal with matching email (see POST /api/business-auth/team/accept-invite).
model BusinessMemberInvite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  expiresAt DateTime
  token     String   @unique

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  email     String
  role      BusinessRole
  invitedByUserId String?

  acceptedAt DateTime?

  @@index([businessId])
  @@index([email])
}

model BusinessMember {
  id        String   @id @default(uuid())
  joinedAt  DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  role      BusinessRole @default(DEVELOPER)
  isActive  Boolean       @default(true)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

model FeeSchedule {
  id        String   @id @default(uuid())

  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  flatFee       Decimal  @default(0) @db.Decimal(18, 2) // e.g. $0.50 per tx
  percentageFee Decimal  @default(1) @db.Decimal(5, 2)  // e.g. 1.0%
  maxFee        Decimal? @db.Decimal(18, 2)
}

model PayoutMethod {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  type      PayoutMethodType
  currency  String // e.g. "USD", "USDC", "GHS"
  details   Json   // Encrypted blob: { accountNumber, bankCode } or { walletAddress } etc.
  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  payouts   Payout[]

  @@index([businessId])
}

model Payout {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  environment MerchantEnvironment @default(LIVE)

  methodId  String
  method    PayoutMethod @relation(fields: [methodId], references: [id], onDelete: Restrict)

  amount    Decimal @db.Decimal(18, 8)
  fee       Decimal @default(0) @db.Decimal(18, 8)
  currency  String
  status    PayoutStatus @default(SCHEDULED)
  reference String?
  batchId   String?

  @@index([businessId])
  @@index([businessId, environment])
  @@index([methodId])
  @@index([status])
}

// --------------------------------------
// Platform Settings (dashboard: general, financials, providers, risk, team, api)
// --------------------------------------
// Single-row-per-key store for platform config. Keys: general, financials, providers, risk, api.

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. "general", "financials", "providers", "risk", "api"
  value     Json     // section-specific shape
  updatedAt DateTime @updatedAt

  @@index([key])
}

enum PlatformAdminRole {
  super_admin
  support
  developer
  viewer
}

// Provider % routing: status, operational, enabled, API key, priority, fee.
enum ProviderRoutingStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model ProviderRouting {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code     String   @unique // e.g. SQUID, LIFI, PAYSTACK, ZERO_X
  name     String?  // display name
  status   ProviderRoutingStatus @default(ACTIVE)
  operational Boolean @default(true) // provider health (currently working)
  enabled  Boolean  @default(true)  // include in routing

  keyHash  String?  // SHA-256 of API key; never store raw key
  keyPrefix String? // first 7 chars for display (e.g. "sk_live")

  priority Int     @default(0) // higher = prefer in routing (e.g. 1 = first choice)
  fee      Decimal? @db.Decimal(5, 4) // provider fee e.g. 0.0050 = 0.5%; set later

  @@index([code])
  @@index([enabled, priority])
}

// Lightweight storage for failed order validations (management/debugging).
model FailedOrderValidation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  reason   String   // human-readable error
  code     String?  // e.g. INSUFFICIENT_FUNDS, PROVIDER_DISABLED
  payload  Json     // summary: action, f_chain, t_chain, f_token, t_token, f_amount, t_amount, f_provider, t_provider
  requestId String?  // optional link to request

  @@index([createdAt])
  @@index([code])
}

model PlatformAdmin {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  email         String   @unique
  name          String?
  role          PlatformAdminRole @default(viewer)
  twoFaEnabled  Boolean  @default(false)

  passwordHash   String?   // argon2; null until account setup after invite
  totpSecret     String?   // encrypted TOTP secret for authenticator app
  emailVerifiedAt DateTime? // set when invite is used (signup completes)

  sentInvites    AdminInvite[]  @relation("Inviter")
  sessions       AdminSession[]
  passkeys       AdminPasskey[]

  @@index([email])
  @@index([role])
}

// Invitation for new platform admin. Only super_admin can invite. Token in email link; verify then setup (password, TOTP, passkey).
model AdminInvite {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  email       String
  role        PlatformAdminRole
  token       String   @unique // secure token for invite link; single-use
  expiresAt   DateTime
  usedAt      DateTime? // set when admin completes setup

  invitedById String?
  inviter     PlatformAdmin? @relation("Inviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// Session for dashboard login. TTL 15 or 30 minutes; token in cookie or Authorization header.
model AdminSession {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())

  adminId          String
  admin            PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  tokenHash        String   @unique // SHA-256 of session token; never store raw token
  expiresAt        DateTime
  sessionTtlMinutes Int     @default(15) // 15 or 30

  @@index([adminId])
  @@index([tokenHash])
  @@index([expiresAt])
}

// WebAuthn passkey credential for passwordless login.
model AdminPasskey {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())

  adminId      String
  admin        PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  credentialId String   @unique // WebAuthn credential ID (base64url)
  publicKey    Bytes    // COSE public key
  counter      Int      @default(0)
  name         String?  // optional label, e.g. "MacBook"

  @@index([adminId])
  @@index([credentialId])
}

// --------------------------------------
// API Key Management
// --------------------------------------

model ApiKey {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keyHash    String   @unique // SHA-256 hash of the raw key; never store the raw key
  keyPrefix  String   // First 7 characters of the key (e.g. "pk_live") for identification
  name       String   // e.g. "Backend Server", "Partner X"
  domains    String[] // Allowed origins, e.g. ["admin.myapp.com"]; use ["*"] for all
  permissions String[] // Scopes, e.g. ["READ_ONLY", "ADMIN"]; use ["*"] for super admin

  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?

  businessId String?  // If null: platform admin key; if set: merchant key
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Merchant keys: TEST vs LIVE. Platform keys: null (use LIVE for all operations).
  environment MerchantEnvironment?

  @@index([keyHash])
  @@index([isActive])
  @@index([businessId])
}

// --------------------------------------
// Paystack Payment Record (audit / disputes)
// --------------------------------------
// Per Paystack: store transaction ID as unsigned 64-bit; we use String to avoid JS number precision.
// Persisted on verify and on webhook charge.success/charge.failed for cross-checks and disputes.

model PaystackPaymentRecord {
  id               String    @id @default(uuid())
  reference        String    @unique // Paystack reference (e.g. from initialize)
  paystackId       String    // Paystack transaction ID (string for 64-bit safety)
  transactionId    String?   // Our Transaction UUID
  transaction      Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  status           String    // success | failed | abandoned
  amount           Decimal?  @db.Decimal(18, 8)
  currency         String?
  paidAt           DateTime?
  channel          String?   // card, bank, mobile_money, etc.
  gatewayResponse  String?
  customerEmail    String?
  metadata         Json?     // Paystack metadata (e.g. our transaction_id)
  rawResponse      Json?     // Full verify response for disputes
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([transactionId])
  @@index([paystackId])
  @@index([status])
}

// --------------------------------------
// Paystack Payout Request (offramp)
// --------------------------------------
// Generated after confirming prior crypto transaction; frontend uses code to execute payout.

model PayoutRequest {
  id                 String   @id @default(uuid())
  code               String   @unique // Short id for URL (e.g. nanoid); used by frontend to trigger payout
  transactionId      String   // Our Transaction id (crypto tx that was confirmed)
  transaction        Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  status             String   @default("pending") // pending | completed | failed
  amount             Decimal? @db.Decimal(18, 8) // Set when payout is executed
  currency           String?  // e.g. NGN, GHS
  recipientCode      String?  // Paystack recipient_code after creating recipient
  recipientName      String?  // Recipient name (for display in dashboard)
  recipientType      String?  // nuban | mobile_money
  transferCode       String?  // Paystack transfer_code from execute; use for tracking
  transferReference  String?  // Paystack transfer reference; use with GET .../payouts/verify/:reference
  paystackTransferRecords PaystackTransferRecord[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([transactionId])
  @@index([status])
}

// --------------------------------------
// Paystack Transfer Record (audit / dashboard)
// --------------------------------------
// Persisted when a payout is executed so we can review transfer history in DB.

model PaystackTransferRecord {
  id               String    @id @default(uuid())
  reference        String    @unique // Paystack transfer reference
  transferCode     String    // Paystack transfer_code
  payoutRequestId  String?
  payoutRequest    PayoutRequest? @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)
  amount           Decimal   @db.Decimal(18, 8)
  currency         String
  status           String    // success | pending | failed | reversed | otp
  recipientName    String?
  reason           String?
  rawResponse      Json?     // Sanitized transfer data for review
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([payoutRequestId])
  @@index([status])
  @@index([transferCode])
}

// --------------------------------------
// Invoices (dashboard feature)
// --------------------------------------

model Invoice {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Merchant scope (nullable until existing rows are backfilled).
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  environment MerchantEnvironment @default(LIVE)

  invoiceNumber String   @unique
  status        InvoiceStatus
  amount        Decimal  @db.Decimal(18, 2)
  currency      String   @default("USD")
  currencyLabel String?
  paidAt        DateTime?

  batchTitle     String  @default("")
  billedTo       String
  billingDetails String?
  subject        String
  issued         DateTime
  dueDate        DateTime
  notes          String?

  lineItems Json // LineItem[]: { id, productName, qty, unitPrice, amount }
  subtotal  Decimal @db.Decimal(18, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal @default(0) @db.Decimal(18, 2)
  total     Decimal @db.Decimal(18, 2)
  amountDue Decimal @db.Decimal(18, 2)

  termsAndConditions String @default("")
  notesContent       String @default("")
  log                Json   // LogEntry[]: { id, description, date }

  @@index([status])
  @@index([billedTo])
  @@index([issued])
  @@index([businessId])
  @@index([businessId, environment])
}

// --------------------------------------
// Merchant webhooks & refunds (B2B SaaS)
// --------------------------------------

model WebhookEndpoint {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  environment MerchantEnvironment @default(LIVE)

  url    String
  secret String?
  events String[]
  isActive Boolean @default(true)

  deliveries WebhookDeliveryLog[]

  @@index([businessId])
  @@index([businessId, environment])
}

model WebhookDeliveryLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  eventType String
  payload   Json

  httpStatus   Int?
  responseBody String? @db.Text
  status       WebhookDeliveryStatus @default(PENDING)
  attemptCount Int     @default(0)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([endpointId])
  @@index([createdAt])
  @@index([transactionId])
}

model Refund {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  environment MerchantEnvironment @default(LIVE)

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  amount   Decimal @db.Decimal(18, 8)
  currency String
  status   RefundStatus @default(PENDING)
  reason   String?

  requestedByUserId String?
  cryptoTxHash      String?
  failureReason     String?

  @@index([businessId])
  @@index([businessId, environment])
  @@index([transactionId])
}
