// Prisma schema - Crypto Payment System (Central Point)
// See md/rules for conventions.
// Prisma 7: provider prisma-client, output required; datasource url in prisma.config.ts

generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------
// Enums
// --------------------------------------

enum TransactionType {
  BUY
  SELL
  TRANSFER
  REQUEST
  CLAIM
}

enum TransactionStatus {
  ACTIVE
  PENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum ClaimStatus {
  ACTIVE
  CLAIMED
  CANCELLED
  FAIL
}

enum PaymentProvider {
  NONE
  ANY
  KLYRA   // On-chain same-chain; we have balance and send to user
  SQUID
  LIFI
  PAYSTACK
}

enum CryptoTransactionStatus {
  PENDING   // Quote accepted; swap not yet submitted
  SUBMITTED // Tx sent to chain; awaiting confirmation
  CONFIRMED // On-chain confirmed
  FAILED    // Submit failed or chain reverted
}

enum IdentityType {
  ADDRESS
  EMAIL
  NUMBER
}

enum SupportedChain {
  ETHEREUM
  BNB
  BASE
  SOLANA
}

enum InvoiceStatus {
  Paid
  Pending
  Overdue
  Draft
  Cancelled
}

// --------------------------------------
// Enums (Business / B2B2C)
// --------------------------------------

enum BusinessRole {
  OWNER
  ADMIN
  DEVELOPER
  FINANCE
  SUPPORT
}

enum KybStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
  RESTRICTED // Frozen funds
}

enum SettlementSchedule {
  INSTANT
  DAILY
  WEEKLY
  MANUAL
}

enum PayoutMethodType {
  BANK_ACCOUNT
  CRYPTO_WALLET
  MOBILE_MONEY
}

enum PayoutStatus {
  SCHEDULED
  PROCESSING
  PAID
  FAILED
  REVERSED
}

// --------------------------------------
// Core Models
// --------------------------------------

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email    String  @unique
  address  String? @unique
  number   String? // e.g. 233...
  username String?

  transactionsFrom Transaction[] @relation("FromUser")
  transactionsTo   Transaction[] @relation("ToUser")
  members          BusinessMember[]

  @@index([email, address, username])
}

model Transaction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type   TransactionType
  status TransactionStatus @default(ACTIVE)

  fromIdentifier String?
  fromType       IdentityType?
  fromUserId     String?
  fromUser       User?         @relation("FromUser", fields: [fromUserId], references: [id])

  toIdentifier String?
  toType       IdentityType?
  toUserId     String?
  toUser       User?         @relation("ToUser", fields: [toUserId], references: [id])

  f_amount Decimal @db.Decimal(18, 8)
  t_amount Decimal @db.Decimal(18, 8)
  f_price  Decimal @db.Decimal(18, 8)
  t_price  Decimal @db.Decimal(18, 8)

  f_chain  String  // Source chain (e.g. ETHEREUM, BASE)
  t_chain  String  // Target chain (e.g. ETHEREUM, BASE) — enables cross-chain e.g. USDC on BASE → USDT on ETHEREUM
  f_token  String
  t_token  String

  f_provider PaymentProvider @default(NONE)
  t_provider PaymentProvider @default(NONE)

  providerSessionId String? // External provider session (e.g. PayStack); link for session-based providers

  businessId String? // Optional: if this tx was initiated via API by a merchant
  business   Business? @relation("BusinessTransactions", fields: [businessId], references: [id], onDelete: SetNull)

  platformFee Decimal? @default(0) @db.Decimal(18, 8) // Platform cut
  merchantFee Decimal? @default(0) @db.Decimal(18, 8) // Merchant markup (if any)
  fee        Decimal? @db.Decimal(18, 8) // Fee charged for this transaction (set when status = COMPLETED)
  providerPrice Decimal? @db.Decimal(18, 8) // Provider quote at order time (e.g. onramp: provider buy price)

  request   Request?
  requestId String?  @unique

  payoutRequests PayoutRequest[]
  paystackPaymentRecords PaystackPaymentRecord[]
  cryptoTransactions CryptoTransaction[]
  transactionPnLs TransactionPnL[]

  @@index([status, type])
  @@index([businessId])
}

// Profit & loss per lot used in a sale (FIFO). fee = selling - provider; profit = selling - cost.
model TransactionPnL {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  lotId         String?
  lot           InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)

  quantity      Decimal @db.Decimal(28, 8) // tokens sold from this lot
  costPerToken  Decimal @db.Decimal(18, 8) // initial buy price (cost basis)
  providerPrice Decimal @db.Decimal(18, 8) // provider quote at time of sale
  sellingPrice  Decimal @db.Decimal(18, 8) // price we sold to user (e.g. t_price)

  feeAmount   Decimal @db.Decimal(18, 8) // (sellingPrice - providerPrice) * quantity
  profitLoss  Decimal @db.Decimal(18, 8) // (sellingPrice - costPerToken) * quantity

  @@index([transactionId])
  @@index([lotId])
}

// --------------------------------------
// Crypto / Swap Transaction (router audit)
// --------------------------------------
// Tracks swap executions via 0x, Squid, LiFi. When a user picks a quote and proceeds,
// we record the swap; when we have the on-chain tx hash we update. Enables search by
// transaction ID and linking onramp/offramp to Paystack via transactionId.

model CryptoTransaction {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  provider     String   // "0x" | "squid" | "lifi"
  status       CryptoTransactionStatus @default(PENDING)

  fromChainId  Int
  toChainId    Int
  fromToken    String   // Contract address or native
  toToken      String
  fromAmount   String   // Wei/smallest unit
  toAmount     String

  txHash       String?  // Blockchain tx hash once submitted/confirmed
  txUrl        String?  // Block explorer link (optional)

  transactionId String?  // Our business Transaction when part of onramp/offramp
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  metadata     Json?    // Optional: quote snapshot, from_address, to_address, etc.

  @@index([transactionId])
  @@index([txHash])
  @@index([provider, status])
  @@index([createdAt])
}

model Request {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code       String @unique
  linkId     String @unique

  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  claim Claim?
}

model Claim {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestId String  @unique
  request   Request @relation(fields: [requestId], references: [id])

  status ClaimStatus @default(ACTIVE)

  value Decimal @db.Decimal(18, 8)
  price Decimal @db.Decimal(18, 8)
  token String

  payerIdentifier String
  toIdentifier    String

  code String
}

// --------------------------------------
// Internal System Models
// --------------------------------------

model Wallet {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address          String   @unique
  encryptedKey     String
  supportedChains  String[] // e.g. ["ETHEREUM", "BASE"]
  supportedTokens  String[] // e.g. ["ETH", "USDC"]

  inventoryAssets InventoryAsset[]
}

model InventoryAsset {
  id        String   @id @default(uuid())
  updatedAt DateTime @updatedAt

  chain        String   // display name e.g. ETHEREUM, BASE
  chainId      Int      // chain ID e.g. 1, 8453
  tokenAddress String
  symbol       String
  address      String   // wallet/account address that holds this balance (not unique)

  currentBalance Decimal @default(0) @db.Decimal(28, 8)

  walletId String?
  wallet   Wallet?           @relation(fields: [walletId], references: [id], onDelete: SetNull)
  history  InventoryHistory[]
  lots     InventoryLot[]

  @@unique([chainId, tokenAddress, address])
  @@index([address])
  @@index([walletId])
}

// Order-book style lots: each acquisition is a lot with cost basis. Fulfill sell orders FIFO.
model InventoryLot {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  assetId String
  asset   InventoryAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  quantity   Decimal @db.Decimal(28, 8)  // remaining quantity in this lot
  costPerToken Decimal @db.Decimal(18, 8) // price we paid per token (cost basis)
  acquiredAt DateTime @default(now())

  sourceType          String?  // e.g. PURCHASE, REBALANCE
  sourceTransactionId String? // link to Transaction when from an order

  transactionPnLs TransactionPnL[]

  @@index([assetId, acquiredAt])
  @@index([sourceTransactionId])
}

model InventoryHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  assetId String
  asset   InventoryAsset @relation(fields: [assetId], references: [id])

  type     String
  amount   Decimal @db.Decimal(28, 8)
  quantity Decimal @db.Decimal(28, 8)

  initialPurchasePrice Decimal @db.Decimal(18, 8)
  providerQuotePrice   Decimal @db.Decimal(18, 8)
}

// --------------------------------------
// Supported Countries (onramp/offramp, payouts)
// --------------------------------------
// Country code (e.g. GH, NG), currency (e.g. GHS, NGN). Used for quotes and payouts.
// supportedFonbnk / supportedPaystack indicate which provider supports this country.

model Country {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code             String   @unique // ISO 3166-1 alpha-2, e.g. GH, NG
  name             String   // e.g. Ghana, Nigeria
  currency         String   // ISO 4217, e.g. GHS, NGN
  supportedFonbnk  Boolean  @default(false)
  supportedPaystack Boolean @default(false)

  @@index([code])
  @@index([supportedFonbnk, supportedPaystack])
}

// --------------------------------------
// Supported Chains & Tokens (onramp/offramp, quotes, transfers)
// --------------------------------------
// Managed via admin; consumed by GET /api/chains and GET /api/tokens.
// Used for pool-token lookup (Fonbnk intermediate, direct quotes).
// Model "Chain" maps to table "Chain" so the table does not conflict with enum type SupportedChain (ETHEREUM, BNB, BASE, SOLANA).

model Chain {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chainId   Int     @unique // e.g. 8453 (Base), 1 (Ethereum)
  name      String  // e.g. Base, Ethereum
  iconUri   String? // optional chain icon URL

  @@index([chainId])
  @@map("Chain")
}

model SupportedToken {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chainId       Int     // chain ID (e.g. 8453, 1); match Chain.chainId
  tokenAddress  String  // contract address or native sentinel (e.g. 0xEee...)
  symbol        String  // e.g. USDC, ETH
  decimals      Int     @default(18)
  name          String? // e.g. USD Coin
  logoUri       String? // optional token icon URL
  fonbnkCode    String? // Fonbnk NETWORK_ASSET e.g. BASE_USDC, ETHEREUM_NATIVE

  @@unique([chainId, tokenAddress])
  @@index([chainId])
  @@index([symbol])
}

// --------------------------------------
// Business (B2B2C: Platform–Merchant–User)
// --------------------------------------

model Business {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String  // e.g. "Amazon Inc"
  slug         String  @unique // e.g. "amazon" (for public payment links)
  logoUrl      String?
  website      String?
  supportEmail String?

  legalName          String? // Official registered name (KYB)
  registrationNumber String? // Tax ID / EIN / RC Number
  country            String  // ISO code e.g. "GH", "US"
  kybStatus          KybStatus @default(NOT_STARTED)
  riskScore          Int       @default(0) // 0–100, 100 is high risk

  settlementSchedule SettlementSchedule @default(WEEKLY)
  webhookUrl          String? // Main webhook for business events

  members       BusinessMember[]
  apiKeys       ApiKey[]
  transactions  Transaction[]    @relation("BusinessTransactions")
  payoutMethods PayoutMethod[]
  payouts       Payout[]
  feeSchedule   FeeSchedule?
}

model BusinessMember {
  id        String   @id @default(uuid())
  joinedAt  DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  role      BusinessRole @default(DEVELOPER)
  isActive  Boolean       @default(true)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

model FeeSchedule {
  id        String   @id @default(uuid())

  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  flatFee       Decimal  @default(0) @db.Decimal(18, 2) // e.g. $0.50 per tx
  percentageFee Decimal  @default(1) @db.Decimal(5, 2)  // e.g. 1.0%
  maxFee        Decimal? @db.Decimal(18, 2)
}

model PayoutMethod {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  type      PayoutMethodType
  currency  String // e.g. "USD", "USDC", "GHS"
  details   Json   // Encrypted blob: { accountNumber, bankCode } or { walletAddress } etc.
  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  payouts   Payout[]

  @@index([businessId])
}

model Payout {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  methodId  String
  method    PayoutMethod @relation(fields: [methodId], references: [id], onDelete: Restrict)

  amount    Decimal @db.Decimal(18, 8)
  fee       Decimal @default(0) @db.Decimal(18, 8)
  currency  String
  status    PayoutStatus @default(SCHEDULED)
  reference String?
  batchId   String?

  @@index([businessId])
  @@index([methodId])
  @@index([status])
}

// --------------------------------------
// Platform Settings (dashboard: general, financials, providers, risk, team, api)
// --------------------------------------
// Single-row-per-key store for platform config. Keys: general, financials, providers, risk, api.

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. "general", "financials", "providers", "risk", "api"
  value     Json     // section-specific shape
  updatedAt DateTime @updatedAt

  @@index([key])
}

enum PlatformAdminRole {
  super_admin
  support
  developer
  viewer
}

// Provider % routing: status, operational, enabled, API key, priority, fee.
enum ProviderRoutingStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model ProviderRouting {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code     String   @unique // e.g. SQUID, LIFI, PAYSTACK, ZERO_X
  name     String?  // display name
  status   ProviderRoutingStatus @default(ACTIVE)
  operational Boolean @default(true) // provider health (currently working)
  enabled  Boolean  @default(true)  // include in routing

  keyHash  String?  // SHA-256 of API key; never store raw key
  keyPrefix String? // first 7 chars for display (e.g. "sk_live")

  priority Int     @default(0) // higher = prefer in routing (e.g. 1 = first choice)
  fee      Decimal? @db.Decimal(5, 4) // provider fee e.g. 0.0050 = 0.5%; set later

  @@index([code])
  @@index([enabled, priority])
}

// Lightweight storage for failed order validations (management/debugging).
model FailedOrderValidation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  reason   String   // human-readable error
  code     String?  // e.g. INSUFFICIENT_FUNDS, PROVIDER_DISABLED
  payload  Json     // summary: action, f_chain, t_chain, f_token, t_token, f_amount, t_amount, f_provider, t_provider
  requestId String?  // optional link to request

  @@index([createdAt])
  @@index([code])
}

model PlatformAdmin {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  email         String   @unique
  name          String?
  role          PlatformAdminRole @default(viewer)
  twoFaEnabled  Boolean  @default(false)

  passwordHash   String?   // argon2; null until account setup after invite
  totpSecret     String?   // encrypted TOTP secret for authenticator app
  emailVerifiedAt DateTime? // set when invite is used (signup completes)

  sentInvites    AdminInvite[]  @relation("Inviter")
  sessions       AdminSession[]
  passkeys       AdminPasskey[]

  @@index([email])
  @@index([role])
}

// Invitation for new platform admin. Only super_admin can invite. Token in email link; verify then setup (password, TOTP, passkey).
model AdminInvite {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  email       String
  role        PlatformAdminRole
  token       String   @unique // secure token for invite link; single-use
  expiresAt   DateTime
  usedAt      DateTime? // set when admin completes setup

  invitedById String?
  inviter     PlatformAdmin? @relation("Inviter", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// Session for dashboard login. TTL 15 or 30 minutes; token in cookie or Authorization header.
model AdminSession {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())

  adminId          String
  admin            PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  tokenHash        String   @unique // SHA-256 of session token; never store raw token
  expiresAt        DateTime
  sessionTtlMinutes Int     @default(15) // 15 or 30

  @@index([adminId])
  @@index([tokenHash])
  @@index([expiresAt])
}

// WebAuthn passkey credential for passwordless login.
model AdminPasskey {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())

  adminId      String
  admin        PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  credentialId String   @unique // WebAuthn credential ID (base64url)
  publicKey    Bytes    // COSE public key
  counter      Int      @default(0)
  name         String?  // optional label, e.g. "MacBook"

  @@index([adminId])
  @@index([credentialId])
}

// --------------------------------------
// API Key Management
// --------------------------------------

model ApiKey {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keyHash    String   @unique // SHA-256 hash of the raw key; never store the raw key
  keyPrefix  String   // First 7 characters of the key (e.g. "pk_live") for identification
  name       String   // e.g. "Backend Server", "Partner X"
  domains    String[] // Allowed origins, e.g. ["admin.myapp.com"]; use ["*"] for all
  permissions String[] // Scopes, e.g. ["READ_ONLY", "ADMIN"]; use ["*"] for super admin

  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?

  businessId String?  // If null: platform admin key; if set: merchant key
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([isActive])
  @@index([businessId])
}

// --------------------------------------
// Paystack Payment Record (audit / disputes)
// --------------------------------------
// Per Paystack: store transaction ID as unsigned 64-bit; we use String to avoid JS number precision.
// Persisted on verify and on webhook charge.success/charge.failed for cross-checks and disputes.

model PaystackPaymentRecord {
  id               String    @id @default(uuid())
  reference        String    @unique // Paystack reference (e.g. from initialize)
  paystackId       String    // Paystack transaction ID (string for 64-bit safety)
  transactionId    String?   // Our Transaction UUID
  transaction      Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  status           String    // success | failed | abandoned
  amount           Decimal?  @db.Decimal(18, 8)
  currency         String?
  paidAt           DateTime?
  channel          String?   // card, bank, mobile_money, etc.
  gatewayResponse  String?
  customerEmail    String?
  metadata         Json?     // Paystack metadata (e.g. our transaction_id)
  rawResponse      Json?     // Full verify response for disputes
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([transactionId])
  @@index([paystackId])
  @@index([status])
}

// --------------------------------------
// Paystack Payout Request (offramp)
// --------------------------------------
// Generated after confirming prior crypto transaction; frontend uses code to execute payout.

model PayoutRequest {
  id                 String   @id @default(uuid())
  code               String   @unique // Short id for URL (e.g. nanoid); used by frontend to trigger payout
  transactionId      String   // Our Transaction id (crypto tx that was confirmed)
  transaction        Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  status             String   @default("pending") // pending | completed | failed
  amount             Decimal? @db.Decimal(18, 8) // Set when payout is executed
  currency           String?  // e.g. NGN, GHS
  recipientCode      String?  // Paystack recipient_code after creating recipient
  recipientName      String?  // Recipient name (for display in dashboard)
  recipientType      String?  // nuban | mobile_money
  transferCode       String?  // Paystack transfer_code from execute; use for tracking
  transferReference  String?  // Paystack transfer reference; use with GET .../payouts/verify/:reference
  paystackTransferRecords PaystackTransferRecord[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([transactionId])
  @@index([status])
}

// --------------------------------------
// Paystack Transfer Record (audit / dashboard)
// --------------------------------------
// Persisted when a payout is executed so we can review transfer history in DB.

model PaystackTransferRecord {
  id               String    @id @default(uuid())
  reference        String    @unique // Paystack transfer reference
  transferCode     String    // Paystack transfer_code
  payoutRequestId  String?
  payoutRequest    PayoutRequest? @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)
  amount           Decimal   @db.Decimal(18, 8)
  currency         String
  status           String    // success | pending | failed | reversed | otp
  recipientName    String?
  reason           String?
  rawResponse      Json?     // Sanitized transfer data for review
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([payoutRequestId])
  @@index([status])
  @@index([transferCode])
}

// --------------------------------------
// Invoices (dashboard feature)
// --------------------------------------

model Invoice {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceNumber String   @unique
  status        InvoiceStatus
  amount        Decimal  @db.Decimal(18, 2)
  currency      String   @default("USD")
  currencyLabel String?
  paidAt        DateTime?

  batchTitle     String  @default("")
  billedTo       String
  billingDetails String?
  subject        String
  issued         DateTime
  dueDate        DateTime
  notes          String?

  lineItems Json // LineItem[]: { id, productName, qty, unitPrice, amount }
  subtotal  Decimal @db.Decimal(18, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal @default(0) @db.Decimal(18, 2)
  total     Decimal @db.Decimal(18, 2)
  amountDue Decimal @db.Decimal(18, 2)

  termsAndConditions String @default("")
  notesContent       String @default("")
  log                Json   // LogEntry[]: { id, description, date }

  @@index([status])
  @@index([billedTo])
  @@index([issued])
}
