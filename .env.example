# Database (PostgreSQL). Core uses DATABASE_URL with @prisma/adapter-pg (direct TCP).
# If login returns 503 DATABASE_UNAVAILABLE: wrong password, wrong db name, or host unreachable.
# Supabase: use "Session" pooler URL or direct connection from Project Settings → Database;
#   add ?sslmode=require. Transaction pooler (6543) can cause odd errors with some clients.
DATABASE_URL="postgresql://username:password@127.0.0.1:5432/klyra"
DIRECT_URL="postgresql://username:password@127.0.0.1:5432/klyra"

# Optional: only if BUSINESS_SIGNUP_LANDING_URL is unset — force magic links to Core /signup/business
# BUSINESS_MAGIC_LINK_BASE_URL=http://127.0.0.1:4003

# Redis
REDIS_URL="redis://localhost:6379"

# Encryption (32-byte hex for AES-256)
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# Pusher
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1

# Admin dashboard (optional)
ADMIN_WEBHOOK_URL=

# 0x Swap API (for token swap quotes: GET /api/quote/swap)
# ZEROX_API_KEY=your-0x-api-key

# Server
PORT=4000
NODE_ENV=development

# Where Google OAuth (and similar) sends the user after login: ?portal_token=<jwt>
# Dev default in code is http://localhost:3001/business/signup if unset.
BUSINESS_SIGNUP_LANDING_URL=http://localhost:3001/business/signup

# API Key (for Backend Server / partners; set after running pnpm key:generate)
# CORE_API_KEY=sk_live_...

# Live test script (pnpm test:live)
# CORE_URL=http://localhost:4000
# INTERVAL_MIN_MS=3000
# INTERVAL_MAX_MS=60000
